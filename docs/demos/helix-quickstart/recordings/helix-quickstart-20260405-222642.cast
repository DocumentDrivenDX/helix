[127.69126, "o", "import assert from 'assert';\r\nimport { toFahrenheit, toCelsius } from '../bin/convert.js';\r\n\r\ndescribe('Temperature Conversion', () => {\r\n  describe('toFahrenheit', () => {\r\n    it('should convert 0В°C to 32В°F', () => {\r\n      assert.strictEqual(toFahrenheit(0), 32);\r\n    });\r\n  });\r\n\r\n  describe('toCelsius', () => {\r\n    it('should convert 212В°F to 100В°C', () => {\r\n      assert.strictEqual(toCelsius(212), 100);\r\n    });\r\n\r\n    it('should convert 98.6В°F to approximately 37.0В°C', () => {\r\n"]
