#!/usr/bin/env bash
# bin/helix — plugin-mode CLI wrapper
#
# When HELIX is loaded as a Claude Code plugin, the plugin loader adds bin/
# to PATH. This wrapper resolves HELIX_ROOT from CLAUDE_PLUGIN_ROOT and
# delegates to scripts/helix.
#
# CLAUDE_PLUGIN_ROOT is set by the plugin loader when the plugin is active.
# Fall back to the directory containing this script's parent when running
# outside of plugin mode (e.g., direct invocation during development).

set -euo pipefail

if [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
  HELIX_ROOT="${CLAUDE_PLUGIN_ROOT}"
else
  # Resolve the bin/ directory's parent as the plugin root
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  HELIX_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi

export HELIX_ROOT

exec "${HELIX_ROOT}/scripts/helix" "$@"
