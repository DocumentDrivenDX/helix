{
  "assert": "stream_json_tool_use",
  "expect_tool_use": {
    "name_regex": "^Write$",
    "path_regex": "^docs/adr/\\d{4}.*\\.md$",
    "content_regex": "library_type:\\s*library:adr"
  },
  "secondary": {
    "assert": "prose_match",
    "must_not_match": [
      "(?i)docs/helix/02-design",
      "(?i)helix-library.*(not installed|missing)"
    ]
  },
  "rationale": "helix-infra routes; ADR goes to docs/adr/NNNN-*.md with library:adr frontmatter."
}
