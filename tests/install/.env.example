# tests/install/ environment variables
#
# Copy to .env and fill in the values you have. The harness reads .env
# from this directory; .env is gitignored (see .gitignore at repo root).

# --- Functional check gate --------------------------------------------------
# When unset/empty: only static checks run (free, no LLM cost).
# When `1`: each runtime scenario runs a non-interactive prompt and asserts
# the response names known HELIX modes. Requires per-runtime auth.
TEST_FUNCTIONAL=

# --- Genie scenario gate ----------------------------------------------------
# When unset/empty: genie scenario warns and skips if creds are missing.
# When `1`: genie scenario fails if DATABRICKS_HOST/TOKEN are missing.
TEST_GENIE=

# --- Per-runtime auth -------------------------------------------------------

# Claude Code: required when TEST_FUNCTIONAL=1
ANTHROPIC_API_KEY=

# OpenAI Codex CLI: required when TEST_FUNCTIONAL=1
OPENAI_API_KEY=

# GitHub Copilot CLI: required when TEST_FUNCTIONAL=1
# Token holder must have an active Copilot license (Pro/Business/Enterprise).
GH_TOKEN=

# Databricks Genie Code: required for genie scenario (any mode)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
# Optional: alternative to HOST+TOKEN via ~/.databrickscfg sections
DATABRICKS_PROFILE=
