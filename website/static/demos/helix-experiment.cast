[77.113832, "o", "\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\n  ACT 4: Results\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\n\r\n"]
[79.116327, "o", "Final state:\r\n"]
[79.116416, "o", "в”Ђв”Ђ src/process.js в”Ђв”Ђ\r\n"]
[79.118242, "o", "// Deliberately slow: rebuilds the string character by character\r\nfunction processStrings(items) {\r\n  const results = [];\r\n  const seen = new Set();\r\n  for (let i = 0; i < items.length; i++) {\r\n    const chars = [];\r\n"]
[79.118408, "o", "    const item = items[i];\r\n    for (let j = 0; j < item.length; j++) {\r\n      chars.push(item[j].toUpperCase());\r\n    }\r\n    const result = chars.join('');\r\n    // Use Set for O(1) duplicate checking instead of O(n) indexOf\r\n    if (!seen.has(result)) {\r\n      seen.add(result);\r\n      results.push(result);\r\n    }\r\n  }\r\n  return results;\r\n}\r\n\r\nmodule.exports = { processStrings };\r\n"]
[79.118547, "o", "...\r\n\r\n"]
[81.124551, "o", "Final benchmark:\r\n$ node benchmark.js\r\n"]
