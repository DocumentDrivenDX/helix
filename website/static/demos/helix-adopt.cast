{"version": 2, "width": 100, "height": 30, "timestamp": 1778788981, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "Adopt HELIX in a new project"}
[0.0, "o", "\r\n\u001b[2m# Day one. You point Claude at an existing repo: a tiny Node converter, source and tests, no HELIX. The agent has no idea what the project cares about.\u001b[0m\r\n"]
[1.0, "o", "\r\n\u001b[1;32m$ ddx install helix\u001b[0m\r\n"]
[1.4, "o", "Installing HELIX skill into ~/.claude/skills/...\r\n\u2713 skill: helix\r\n\u2713 artifact templates: 32 types under helix/workflows/\r\n"]
[1.5, "o", "\r\n\u001b[2m# The skill lands. No CLI to learn. The agent now knows the artifact-type catalog, and one ask is enough.\u001b[0m\r\n"]
[3.0, "o", "\r\n\u001b[36m> /helix what do I have?\u001b[0m\r\n"]
[4.0, "o", "\u001b[2m  \u2699 Bash(command='ls -la .', description='List project root contents')\u001b[0m\r\n"]
[4.5, "o", "\u001b[2m  \u2192 drwxrwxr-x   - erik 14 May 16:02 .claude\r\n.rw-r--r-- 152 erik 14 May 06:44 package.json\r\n.rw-r--r-- 339 erik 14 May 06:44 README.md\r\ndrwxr-xr-x   - erik 14 May 06:44 src\r\ndrwxr-xr-x   - erik 14 May 06:44 tests\u001b[0m\r\n"]
[4.8, "o", "\u001b[2m  \u2699 Bash(command='ls -la .claude/ src/ tests/', description='List .claude, src, tests contents')\u001b[0m\r\n"]
[5.3, "o", "\u001b[2m  \u2192 .claude/:\r\ndrwxrwxr-x - erik 14 May 16:02 skills\r\n\r\nsrc/:\r\n.rw-r--r-- 429 erik 14 May 06:44 convert.js\r\n\r\ntests/:\r\n.rw-r--r-- 444 erik 14 May 06:44 convert.test.js\u001b[0m\r\n"]
[5.6, "o", "\u001b[2m  \u2699 Read(file_path='README.md')\u001b[0m\r\n"]
[6.1, "o", "\u001b[2m  \u2192 19 lines\u001b[0m\r\n"]
[6.4, "o", "\u001b[2m  \u2699 Read(file_path='package.json')\u001b[0m\r\n"]
[6.9, "o", "\u001b[2m  \u2192 10 lines\u001b[0m\r\n"]
[7.2, "o", "\u001b[2m  \u2699 Bash(command=\"ls -la .claude/skills/ && find . -type d -name 'helix' -o -name 'docs' -o -name '.helix' -o -name 'ddx'\", description='Search for HELIX/DDx directories')\u001b[0m\r\n"]
[7.7, "o", "\u001b[2m  \u2192 drwxr-xr-x - erik 14 May 15:09 helix\r\n./.claude/skills/helix\u001b[0m\r\n"]
[8.0, "o", "\r\n\u001b[2m# Inventory, not execution. The router reads the repo, names what's there, and proposes routes. No HELIX artifacts yet.\u001b[0m\r\n"]
